# nginx reverse proxy with Authelia SSO — generated by Ansible
# 3 tiers: True SSO (Remote-User), Authelia gate, Passthrough

worker_processes auto;
events { worker_connections 1024; }

http {
    resolver 127.0.0.11 valid=30s;

    # SSL settings
    ssl_certificate     /etc/nginx/certs/homelab.crt;
    ssl_certificate_key /etc/nginx/certs/homelab.key;
    ssl_protocols       TLSv1.2 TLSv1.3;

    # Authelia endpoint for auth_request
    upstream authelia {
        server authelia:9091;
    }

    # --- Authelia itself ---
    server {
        listen 443 ssl;
        server_name auth.{{ homelab_domain }};
        location / {
            proxy_pass http://authelia:9091;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

    # --- Authelia auth_request snippet (used by Tier 1 and Tier 2) ---
    # Internal location for auth verification
    # Include this via: include /etc/nginx/authelia-location.conf;

    # === TIER 1 — True SSO (auth_request + Remote-User header) ===
{% for svc in sso_tier1_services %}
    server {
        listen 443 ssl;
        server_name {{ svc.name }}.{{ homelab_domain }};

        location /authelia {
            internal;
            proxy_pass http://authelia:9091/api/authz/forward-auth;
            proxy_set_header X-Original-URL $scheme://$host$request_uri;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Host $host;
        }

        location / {
            auth_request /authelia;
            auth_request_set $user $upstream_http_remote_user;
            proxy_set_header Remote-User $user;
            proxy_pass http://{{ svc.name }}:{{ svc.port }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        error_page 401 =302 https://auth.{{ homelab_domain }}/?rd=$scheme://$host$request_uri;
    }

{% endfor %}
    # === TIER 2 — Authelia gate (no built-in auth in service) ===
{% for svc in sso_tier2_services %}
    server {
        listen 443 ssl;
        server_name {{ svc.name }}.{{ homelab_domain }};

        location /authelia {
            internal;
            proxy_pass http://authelia:9091/api/authz/forward-auth;
            proxy_set_header X-Original-URL $scheme://$host$request_uri;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Host $host;
        }

        location / {
            auth_request /authelia;
            proxy_pass http://{{ svc.name }}:{{ svc.port }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        error_page 401 =302 https://auth.{{ homelab_domain }}/?rd=$scheme://$host$request_uri;
    }

{% endfor %}
    # === TIER 3 — Passthrough (service handles its own auth) ===
{% for svc in sso_tier3_services %}
    server {
        listen 443 ssl;
        server_name {{ svc.name }}.{{ homelab_domain }};

        location / {
            proxy_pass http://{{ svc.name }}:{{ svc.port }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
        }
    }

{% endfor %}
}
