---
# Authelia configuration — generated by Ansible

server:
  address: 'tcp://:9091'

log:
  level: info

jwt_secret: '{{ vault_authelia_jwt_secret }}'

authentication_backend:
  file:
    path: /config/users_database.yml

session:
  secret: '{{ vault_authelia_session_secret }}'
  cookies:
    - domain: '{{ homelab_domain }}'
      authelia_url: 'https://auth.{{ homelab_domain }}'
      expiration: '{{ authelia_session_expiration }}'
      inactivity: '{{ authelia_session_inactivity }}'

storage:
  encryption_key: '{{ vault_authelia_storage_encryption_key }}'
  local:
    path: /config/db.sqlite3

notifier:
  filesystem:
    filename: /config/notification.txt

access_control:
  default_policy: one_factor
  rules:
    # Tier 1 — True SSO services (auth_request + Remote-User)
{% for svc in sso_tier1_services %}
    - domain: '{{ svc.name }}.{{ homelab_domain }}'
      policy: one_factor
{% endfor %}

    # Tier 2 — Authelia gate (services with no built-in auth)
{% for svc in sso_tier2_services %}
    - domain: '{{ svc.name }}.{{ homelab_domain }}'
      policy: one_factor
{% endfor %}

    # Tier 3 — Passthrough (services handle their own auth)
{% for svc in sso_tier3_services %}
    - domain: '{{ svc.name }}.{{ homelab_domain }}'
      policy: bypass
{% endfor %}
