---
# Authelia file-based user database — generated by Ansible
#
# To generate a password hash:
#   docker run authelia/authelia:latest authelia crypto hash generate argon2 --password 'YOUR_PASSWORD'

users:
  {{ vault_authelia_user }}:
    displayname: '{{ vault_authelia_display_name }}'
    password: '{{ vault_authelia_password_hash }}'
    email: '{{ vault_authelia_email }}'
    groups:
      - admins
