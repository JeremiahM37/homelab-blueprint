#!/usr/bin/env bash
# Restic backup script for {{ inventory_hostname }} — generated by Ansible
set -euo pipefail

export RESTIC_PASSWORD="{{ vault_restic_password }}"
{% if inventory_hostname == 'mediaserver' %}
REPO="{{ restic_repo_path }}"
{% else %}
REPO="sftp:root@{{ hostvars['mediaserver']['ansible_host'] }}:{{ restic_repo_path }}"
{% endif %}

echo "[$(date)] Starting backup for {{ inventory_hostname }}"

{% set config = backup_configs[inventory_hostname] %}
restic -r "$REPO" backup \
{% for path in config.paths %}
  {{ path }} \
{% endfor %}
{% for excl in config.excludes %}
  --exclude '{{ excl }}' \
{% endfor %}
  --host {{ config.hostname }} \
  --tag {{ inventory_hostname }}

echo "[$(date)] Running retention policy"
restic -r "$REPO" forget \
  --keep-daily {{ restic_retention_daily }} \
  --keep-weekly {{ restic_retention_weekly }} \
  --keep-monthly {{ restic_retention_monthly }} \
  --host {{ config.hostname }} \
  --prune

echo "[$(date)] Backup complete for {{ inventory_hostname }}"
