# Docker Compose .env file — generated by Ansible
# Do not edit manually; re-run the playbook to update.

# General
TZ={{ timezone }}
PUID={{ docker_puid }}
PGID={{ docker_pgid }}

# VPN (gluetun)
VPN_SERVICE_PROVIDER={{ vpn_provider | default('mullvad') }}
VPN_TYPE={{ vpn_type | default('wireguard') }}
WIREGUARD_PRIVATE_KEY={{ vault_vpn_private_key }}
WIREGUARD_ADDRESSES={{ vault_vpn_address }}/32
SERVER_COUNTRIES={{ vpn_country | default('us') }}

# qBittorrent
QBIT_USER={{ vault_qbit_user }}
QBIT_PASS={{ vault_qbit_password }}

# Prowlarr
PROWLARR_API_KEY={{ vault_prowlarr_api_key }}

# Sonarr
SONARR_API_KEY={{ vault_sonarr_api_key }}

# Radarr
RADARR_API_KEY={{ vault_radarr_api_key }}

# Jellyfin
JELLYFIN_API_KEY={{ vault_jellyfin_api_key }}

# Jellyseerr
JELLYSEERR_API_KEY={{ vault_jellyseerr_api_key }}

# Librarr
LIBRARR_USER={{ vault_librarr_user }}
LIBRARR_PASS={{ vault_librarr_password }}
TORZNAB_API_KEY={{ vault_torznab_api_key }}

# Sentinel
ABS_TOKEN={{ vault_abs_token }}
KAVITA_API_KEY={{ vault_kavita_api_key }}
SENTINEL_DISCORD_WEBHOOK={{ vault_sentinel_discord_webhook }}

# Database credentials
DB_USER={{ vault_db_user }}
DB_PASS={{ vault_db_password }}
DB_ROOT_PASS={{ vault_db_root_password }}

# Paperless
PAPERLESS_SECRET={{ vault_paperless_secret }}

# Linkwarden
NEXTAUTH_SECRET={{ vault_linkwarden_secret }}

# n8n
N8N_USER={{ vault_n8n_user }}
N8N_PASS={{ vault_n8n_password }}

# Cloudflare
TUNNEL_TOKEN={{ vault_cloudflare_tunnel_token }}

# Discord Bot
DISCORD_TOKEN={{ vault_discord_bot_token }}
