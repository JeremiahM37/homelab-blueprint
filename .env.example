# Docker Compose environment — copy to .env next to docker-compose.yml and
# fill in your own values. NEVER commit the filled-in .env (it is gitignored).
#
# If you deploy with Ansible, the docker-host role generates this file from
# the vault_* variables in ansible/inventory.yml — you don't edit it by hand.

# General
TZ=America/Denver
PUID=1000
PGID=1000

# VPN (gluetun) — WireGuard key/address from your VPN provider account
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=YOUR_VPN_PRIVATE_KEY
WIREGUARD_ADDRESSES=10.0.0.2/32
SERVER_COUNTRIES=us

# qBittorrent (WebUI login)
QBIT_USER=YOUR_QBIT_USER
QBIT_PASS=YOUR_QBIT_PASSWORD

# *arr API keys (Settings > General in each app after first run)
PROWLARR_API_KEY=YOUR_PROWLARR_API_KEY
SONARR_API_KEY=YOUR_SONARR_API_KEY
RADARR_API_KEY=YOUR_RADARR_API_KEY
JELLYFIN_API_KEY=YOUR_JELLYFIN_API_KEY
JELLYSEERR_API_KEY=YOUR_JELLYSEERR_API_KEY

# Librarr (book search/download service)
LIBRARR_USER=YOUR_LIBRARR_USER
LIBRARR_PASS=YOUR_LIBRARR_PASSWORD
TORZNAB_API_KEY=YOUR_TORZNAB_API_KEY

# Sentinel (download guardian)
ABS_TOKEN=YOUR_AUDIOBOOKSHELF_TOKEN
KAVITA_API_KEY=YOUR_KAVITA_API_KEY
SENTINEL_DISCORD_WEBHOOK=YOUR_DISCORD_WEBHOOK_URL

# Database credentials (shared by gamevault/romm/linkwarden DBs)
DB_USER=YOUR_DB_USER
DB_PASS=YOUR_DB_PASSWORD
DB_ROOT_PASS=YOUR_DB_ROOT_PASSWORD

# Paperless (random secret key, e.g. `openssl rand -hex 32`)
PAPERLESS_SECRET=YOUR_RANDOM_SECRET_KEY

# Linkwarden (random NextAuth secret, e.g. `openssl rand -hex 32`)
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET

# n8n (basic auth login)
N8N_USER=YOUR_N8N_USER
N8N_PASS=YOUR_N8N_PASSWORD

# Cloudflare Tunnel (Zero Trust dashboard > Tunnels)
TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN

# Discord bot
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
